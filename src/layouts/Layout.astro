---
import crypto from 'node:crypto';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  noindex?: boolean;
}

const {
  title = 'EquiPaws',
  description = 'Find your zen with cat-inspired meditation. Guided breathing exercises, mindfulness sessions, and feline wisdom to help you relax.',
  canonicalPath = '',
  noindex = false,
} = Astro.props;

const siteUrl = Astro.site?.href || '';
const canonicalUrl = `${siteUrl.replace(/\/$/, '')}${canonicalPath}`;

const sitePassword = import.meta.env.SITE_PASSWORD || 'changeme';
const passwordHash = crypto.createHash('sha256').update(sitePassword).digest('hex');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#e0ad42" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fredoka:wght@300..700&family=Nunito:ital,wght@0,200..1000;1,200..1000&family=Patrick+Hand&display=swap"
      rel="stylesheet"
    />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebApplication',
        name: 'Purrfectly Zen',
        description: 'Cat-inspired meditation and mindfulness application',
        applicationCategory: 'HealthApplication',
        operatingSystem: 'Web',
        offers: {
          '@type': 'Offer',
          price: '0',
          priceCurrency: 'USD',
        },
      })}
    />
  </head>
  <body>
    <div id="auth-overlay">
      <div class="auth-card">
        <div class="auth-icon">🔒</div>
        <h1 class="auth-title">Zugang geschützt</h1>
        <p class="auth-subtitle">Bitte Passwort eingeben</p>
        <form id="auth-form">
          <input
            type="password"
            id="auth-password"
            placeholder="Passwort"
            autocomplete="current-password"
            required
          />
          <button type="submit">Anmelden</button>
          <p id="auth-error" class="auth-error" style="display:none;">
            Falsches Passwort
          </p>
        </form>
      </div>
    </div>

    <div id="main-content" style="display:none;">
      <slot />
    </div>

    <script define:vars={{ passwordHash }}>
      (async function () {
        const AUTH_KEY = 'site_auth';

        async function sha256(message) {
          const data = new TextEncoder().encode(message);
          if (typeof crypto !== 'undefined' && crypto.subtle) {
            const hashBuffer = await crypto.subtle.digest('SHA-256', data);
            const hashArray = Array.from(new Uint8Array(hashBuffer));
            return hashArray.map((b) => b.toString(16).padStart(2, '0')).join('');
          }
          // Fallback for non-secure contexts (HTTP)
          function rightRotate(value, amount) {
            return (value >>> amount) | (value << (32 - amount));
          }
          const K = [
            0x428a2f98,0x71374491,0xb5c0fbcf,0xe9b5dba5,0x3956c25b,0x59f111f1,0x923f82a4,0xab1c5ed5,
            0xd807aa98,0x12835b01,0x243185be,0x550c7dc3,0x72be5d74,0x80deb1fe,0x9bdc06a7,0xc19bf174,
            0xe49b69c1,0xefbe4786,0x0fc19dc6,0x240ca1cc,0x2de92c6f,0x4a7484aa,0x5cb0a9dc,0x76f988da,
            0x983e5152,0xa831c66d,0xb00327c8,0xbf597fc7,0xc6e00bf3,0xd5a79147,0x06ca6351,0x14292967,
            0x27b70a85,0x2e1b2138,0x4d2c6dfc,0x53380d13,0x650a7354,0x766a0abb,0x81c2c92e,0x92722c85,
            0xa2bfe8a1,0xa81a664b,0xc24b8b70,0xc76c51a3,0xd192e819,0xd6990624,0xf40e3585,0x106aa070,
            0x19a4c116,0x1e376c08,0x2748774c,0x34b0bcb5,0x391c0cb3,0x4ed8aa4a,0x5b9cca4f,0x682e6ff3,
            0x748f82ee,0x78a5636f,0x84c87814,0x8cc70208,0x90befffa,0xa4506ceb,0xbef9a3f7,0xc67178f2
          ];
          const H = [0x6a09e667,0xbb67ae85,0x3c6ef372,0xa54ff53a,0x510e527f,0x9b05688c,0x1f83d9ab,0x5be0cd19];
          const paddedData = new Uint8Array(Math.ceil((data.length + 9) / 64) * 64);
          paddedData.set(data);
          paddedData[data.length] = 0x80;
          const dv = new DataView(paddedData.buffer);
          dv.setUint32(paddedData.length - 4, data.length * 8, false);
          for (let j = 0; j < paddedData.length;) {
            const w = [];
            for (let i = 0; i < 16; i++) { w[i] = dv.getUint32(j, false); j += 4; }
            for (let i = 16; i < 64; i++) {
              const s0 = rightRotate(w[i-15], 7) ^ rightRotate(w[i-15], 18) ^ (w[i-15] >>> 3);
              const s1 = rightRotate(w[i-2], 17) ^ rightRotate(w[i-2], 19) ^ (w[i-2] >>> 10);
              w[i] = (w[i-16] + s0 + w[i-7] + s1) | 0;
            }
            let [a,b,c,d,e,f,g,h] = H;
            for (let i = 0; i < 64; i++) {
              const S1 = rightRotate(e, 6) ^ rightRotate(e, 11) ^ rightRotate(e, 25);
              const ch = (e & f) ^ (~e & g);
              const temp1 = (h + S1 + ch + K[i] + w[i]) | 0;
              const S0 = rightRotate(a, 2) ^ rightRotate(a, 13) ^ rightRotate(a, 22);
              const maj = (a & b) ^ (a & c) ^ (b & c);
              const temp2 = (S0 + maj) | 0;
              h = g; g = f; f = e; e = (d + temp1) | 0;
              d = c; c = b; b = a; a = (temp1 + temp2) | 0;
            }
            H[0] = (H[0]+a)|0; H[1] = (H[1]+b)|0; H[2] = (H[2]+c)|0; H[3] = (H[3]+d)|0;
            H[4] = (H[4]+e)|0; H[5] = (H[5]+f)|0; H[6] = (H[6]+g)|0; H[7] = (H[7]+h)|0;
          }
          return H.map(v => (v >>> 0).toString(16).padStart(8, '0')).join('');
        }

        if (sessionStorage.getItem(AUTH_KEY) === passwordHash) {
          document.getElementById('auth-overlay').style.display = 'none';
          document.getElementById('main-content').style.display = 'block';
        }

        document
          .getElementById('auth-form')
          .addEventListener('submit', async (e) => {
            e.preventDefault();
            const input = document.getElementById('auth-password');
            const hash = await sha256(input.value);
            if (hash === passwordHash) {
              sessionStorage.setItem(AUTH_KEY, passwordHash);
              document.getElementById('auth-overlay').style.display = 'none';
              document.getElementById('main-content').style.display = 'block';
            } else {
              document.getElementById('auth-error').style.display = 'block';
              input.value = '';
              input.focus();
            }
          });
      })();
    </script>
  </body>
</html>

<style is:global>
  @import 'tailwindcss';

  @custom-variant hover (&:hover);

  @theme inline {
    --color-background: hsl(var(--background));
    --color-foreground: hsl(var(--foreground));
    --color-card: hsl(var(--card));
    --color-card-foreground: hsl(var(--card-foreground));
    --color-popover: hsl(var(--popover));
    --color-popover-foreground: hsl(var(--popover-foreground));
    --color-primary: hsl(var(--primary));
    --color-primary-foreground: hsl(var(--primary-foreground));
    --color-secondary: hsl(var(--secondary));
    --color-secondary-foreground: hsl(var(--secondary-foreground));
    --color-muted: hsl(var(--muted));
    --color-muted-foreground: hsl(var(--muted-foreground));
    --color-accent: hsl(var(--accent));
    --color-accent-foreground: hsl(var(--accent-foreground));
    --color-destructive: hsl(var(--destructive));
    --color-destructive-foreground: hsl(var(--destructive-foreground));
    --color-border: hsl(var(--border));
    --color-input: hsl(var(--input));
    --color-ring: hsl(var(--ring));

    --radius-sm: 0.5rem;
    --radius-md: 0.75rem;
    --radius-lg: 1rem;
    --radius-xl: 1.5rem;

    --font-sans: 'Nunito', sans-serif;
    --font-heading: 'Fredoka', sans-serif;
    --font-hand: 'Patrick Hand', cursive;
  }

  :root {
    --background: 35 45% 94%;
    --foreground: 24 45% 18%;

    --primary: 41 73% 57%;
    --primary-foreground: 24 80% 10%;

    --secondary: 64 40% 82%;
    --secondary-foreground: 64 80% 20%;

    --card: 36 35% 97%;
    --card-foreground: 24 45% 18%;

    --popover: 36 35% 97%;
    --popover-foreground: 24 45% 18%;

    --muted: 35 28% 88%;
    --muted-foreground: 24 20% 42%;

    --accent: 34 55% 85%;
    --accent-foreground: 34 70% 22%;

    --destructive: 0 84% 60%;
    --destructive-foreground: 0 0% 98%;

    --border: 35 30% 84%;
    --input: 35 30% 84%;
    --ring: 41 73% 57%;

    --radius: 1rem;
  }

  @layer base {
    html {
      scroll-behavior: smooth;
    }

    * {
      @apply border-border;
    }

    body {
      @apply text-foreground font-sans antialiased;
      background: linear-gradient(
        180deg,
        hsl(35 45% 94%) 0%,
        hsl(34 40% 91%) 25%,
        hsl(33 38% 87%) 50%,
        hsl(30 35% 83%) 75%,
        hsl(28 32% 78%) 100%
      );
      background-attachment: fixed;
    }

    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
      @apply font-sans font-semibold tracking-tight;
    }
  }

  button,
  a,
  nav,
  [role='button'],
  .no-select {
    @apply select-none;
  }

  [role='presentation'],
  .pointer-none,
  svg[aria-hidden='true'] {
    pointer-events: none;
  }

  .absolute.blur-3xl,
  [class*='blob'],
  [class*='pattern'] {
    @apply pointer-events-none;
  }

  svg:not([role='img']) {
    pointer-events: none;
  }

  .font-hand {
    font-family: var(--font-hand);
  }

  #auth-overlay {
    position: fixed;
    inset: 0;
    z-index: 99999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(
      180deg,
      hsl(35 45% 94%) 0%,
      hsl(34 40% 91%) 50%,
      hsl(30 35% 83%) 100%
    );
    font-family: 'Nunito', sans-serif;
  }

  .auth-card {
    background: hsl(36 35% 97%);
    border: 1px solid hsl(35 30% 84%);
    border-radius: 1.5rem;
    padding: 3rem 2.5rem;
    text-align: center;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
    max-width: 380px;
    width: 90%;
  }

  .auth-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .auth-title {
    font-family: 'Fredoka', sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: hsl(24 45% 18%);
    margin: 0 0 0.25rem;
  }

  .auth-subtitle {
    color: hsl(24 20% 42%);
    font-size: 0.95rem;
    margin: 0 0 1.5rem;
  }

  #auth-form input {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid hsl(35 30% 84%);
    border-radius: 0.75rem;
    font-size: 1rem;
    font-family: 'Nunito', sans-serif;
    background: hsl(35 45% 94%);
    color: hsl(24 45% 18%);
    outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }

  #auth-form input:focus {
    border-color: hsl(41 73% 57%);
    box-shadow: 0 0 0 3px hsla(41, 73%, 57%, 0.2);
  }

  #auth-form button {
    width: 100%;
    margin-top: 0.75rem;
    padding: 0.75rem 1rem;
    background: hsl(41 73% 57%);
    color: hsl(24 80% 10%);
    border: none;
    border-radius: 0.75rem;
    font-size: 1rem;
    font-weight: 600;
    font-family: 'Nunito', sans-serif;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  #auth-form button:hover {
    opacity: 0.9;
  }

  .auth-error {
    color: hsl(0 84% 60%);
    font-size: 0.85rem;
    margin-top: 0.75rem;
    margin-bottom: 0;
  }
</style>
